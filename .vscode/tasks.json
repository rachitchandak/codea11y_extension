{
  "version": "2.0.0",
  "tasks": [
    {
      // ── One-shot production build ────────────────────────────────────
      "label": "npm: build",
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": ["$ts-webpack-watch"]
    },
    {
      // ── Continuous watch build (used by the default launch config) ───
      "label": "npm: watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "webpack",
        "pattern": {
          "regexp": "^(ERROR|WARNING)\\s+in\\s+(.+)\\((\\d+),(\\d+)\\)$",
          "severity": 1,
          "file": 2,
          "line": 3,
          "column": 4
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "webpack (is watching|compiling)",
          "endsPattern": "webpack compiled (successfully|with \\d+ error)"
        }
      }
    }
  ]
}
